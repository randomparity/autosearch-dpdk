# local-server build plugin configuration
# Copy to local-server.toml and adjust for your environment.

[build]
# Number of parallel build jobs. 0 means use all available CPU cores.
jobs = 0

# Meson cross-file to use when cross-compiling. Leave empty for native builds.
cross_file = ""

# Additional meson setup arguments passed verbatim (space-separated)
extra_meson_args = ""
