# runner.toml — framework-level runner configuration
# Copy to runner.toml and fill in values for your environment.
# runner.toml is gitignored; never commit host-specific paths.
#
# Plugin-specific settings live in sibling .toml files next to each plugin:
#   builds/local-server.toml    — [build] section
#   tests/testpmd-memif.toml    — [testpmd] + [profiling] sections
#   tests/dts-mlx5.toml         — [test] + [paths] sections
#   perfs/perf-record.toml      — [profiling] section
# Copy each <plugin>.toml.example to <plugin>.toml and configure.

[runner]
# Runner phase: all (default), build, deploy, or test
phase = "all"

# Log level: debug, info, warning, error (also settable via LOG_LEVEL env var)
log_level = "info"

# Optional log file path (logs to both stdout and file when set)
# log_file = "/var/log/autoforge-runner.log"

# Seconds between polling for new requests
poll_interval = 30

[paths]
# Absolute path to the DPDK source tree
dpdk_src = "/home/user/src/dpdk"

# Directory where DPDK build artifacts are written. Created automatically.
build_dir = "/tmp/dpdk-build"

[timeouts]
# Minutes to wait for a full DPDK build before aborting
build_minutes = 30

# Minutes to wait for testpmd measurement to complete
test_minutes = 10
