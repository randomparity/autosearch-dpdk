# runner.toml — machine-local runner configuration
# Copy this file to runner.toml and fill in values for your environment.
# runner.toml is gitignored; never commit host-specific paths or credentials.
#
# Sudo setup (required when testpmd.sudo or profiling.sudo is true):
#   sudo ./scripts/setup-sudo.sh [username] [build_dir]
#
# This grants passwordless sudo for the testpmd binary and perf only.
# See scripts/setup-sudo.sh for details.

[runner]
# Log level: debug, info, warning, error (also settable via LOG_LEVEL env var)
log_level = "info"

# Optional log file path (logs to both stdout and file when set)
# log_file = "/var/log/autosearch-runner.log"

# Seconds between polling for new requests
poll_interval = 30

[paths]
# Absolute path to the DPDK source tree
dpdk_src = "/home/user/src/dpdk"

# Directory where DPDK build artefacts are written. Created automatically.
build_dir = "/tmp/dpdk-build"

# DTS backend only: path to the DTS installation directory
# dts_dir = "/opt/dts"

[timeouts]
# Minutes to wait for a full DPDK build before aborting
build_minutes = 30

# Minutes to wait for testpmd measurement to complete
test_minutes = 10

[build]
# Number of parallel build jobs. 0 means use all available CPU cores.
jobs = 0

# Meson cross-file to use when cross-compiling. Leave empty for native builds.
cross_file = ""

# Additional meson setup arguments passed verbatim (space-separated)
extra_meson_args = ""

[testpmd]
# EAL lcore mask — main lcore + forwarding cores
lcores = "4-7"

# --- Port configuration (choose PCI or vdev, not both) ---

# PCI addresses of the NIC ports (back-to-back connected)
# pci = ["01:00.0", "01:00.1"]

# Virtual devices (e.g. memif pair). Each string is passed as --vdev to EAL.
# WARNING: The memif PMD silently ignores zero-copy=yes on the server role.
# Only the client supports zero-copy. Setting it on a server vdev has no
# effect and may cause misleading performance expectations.
vdev = [
    "net_memif0,role=server,id=0,zero-copy=yes,bsize=2048,rsize=12",
    "net_memif1,role=client,id=0,zero-copy=yes,bsize=2048,rsize=12",
]

# When using vdevs, disable PCI bus scanning
no_pci = true

# Additional EAL arguments passed verbatim (list of strings)
# extra_eal_args = ["--single-file-segments"]

# --- Testpmd application arguments ---

# Number of forwarding cores (excluding main lcore)
nb_cores = 2

# Queues and descriptors per port
rxq = 4
txq = 4
rxd = 4096
txd = 4096

# Burst size for rx/tx
burst = 128

# Forward mode: "io", "macswap", "mac", etc.
forward_mode = "io"

# Seconds to wait after tx_first before resetting stats
warmup_seconds = 5

# Seconds to collect throughput measurement
measure_seconds = 10

# Number of measurement runs; median throughput is reported.
# Use 3-5 for sub-1% gain detection. Default 1 preserves single-run behavior.
repeat_count = 1

# Run testpmd with sudo (requires passwordless sudo for the testpmd binary)
sudo = true

[profiling]
# Capture perf profiles during testpmd measurement window
enabled = false

# Sampling frequency in Hz (99 avoids aliasing with timer interrupts)
frequency = 99

# Run perf commands with sudo (must match testpmd.sudo when profiling testpmd)
sudo = true
